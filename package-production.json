{
  "name": "fieldpulse-production",
  "version": "1.0.0",
  "description": "FieldPulse Marketing Visits App - Production Package",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "npm run build:web",
    "build:web": "expo export --platform web",
    "serve": "npm run build && npm start",
    "install-deps": "npm install --production"
  },
  "dependencies": {
    "expo": "~50.0.0",
    "@expo/vector-icons": "^14.0.0",
    "expo-router": "~3.4.0",
    "react": "18.2.0",
    "react-native": "0.73.0",
    "react-native-web": "~0.19.6",
    "zustand": "^4.4.1",
    "@react-native-async-storage/async-storage": "1.21.0",
    "date-fns": "^2.30.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.2.45",
    "typescript": "^5.1.3"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": ["fieldpulse", "marketing", "visits", "crm"],
  "author": "FieldPulse Team",
  "license": "MIT"
}
